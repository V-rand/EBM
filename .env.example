# EBM Agent OS 环境变量配置（示例）
# 复制为 .env 后填入实际密钥即可使用。
# 用哪个提供商由 config.yaml 中的 provider 字段决定。

# ===== DeepSeek 原生 API（provider: "deepseek"，推荐）=====
DEEPSEEK_API_KEY=sk-your-deepseek-key

# ===== 阿里云百炼 DashScope（provider: "dashscope"）=====
# OPENAI_API_KEY=sk-your-dashscope-key

# ===== PubMed / NCBI（推荐，提升 API 速率限制）=====
NCBI_API_KEY=your-ncbi-api-key

# ===== 网络搜索（推荐至少配置一个）=====
TAVILY_API_KEY=tvly-your-key
SERPER_API_KEY=your-serper-key
JINA_API_KEY=jina-your-key

# ===== 文档解析（可选）=====
MINERU_API_TOKEN=your-mineru-token

# ===== 飞书通知（可选）=====
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxx
FEISHU_SECRET=your-feishu-secret